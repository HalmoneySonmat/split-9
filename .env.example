# Copy to .env (gitignored) and fill in.

# Weights & Biases
WANDB_API_KEY=
WANDB_PROJECT=split-brain-go
WANDB_ENTITY=

# Disable wandb entirely (use TensorBoard only) by uncommenting:
# WANDB_DISABLED=true

# HuggingFace
# Optional, for gated models. Most public models work without this.
HF_TOKEN=

# Faster HF downloads
HF_HUB_ENABLE_HF_TRANSFER=1
